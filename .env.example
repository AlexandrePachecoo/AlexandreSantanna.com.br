# URL pública (usada em meta tags, OG, e geração do link compartilhável)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
SUPABASE_STORAGE_BUCKET=letters

# Melhor Envio (opcional — se ausente, usa tabela fixa por CEP em lib/shipping.js)
# Token de acesso pessoal gerado em melhorenvio.com.br → Configurações → Tokens.
MELHOR_ENVIO_TOKEN=
# 'sandbox' (default) ou 'production'
MELHOR_ENVIO_ENV=sandbox
# CEP de origem (apenas dígitos). Default: Porto Alegre (90040000).
MELHOR_ENVIO_FROM_CEP=90040000
# User-Agent identificando o app — Melhor Envio exige.
MELHOR_ENVIO_USER_AGENT=specialDay (contato@specialday.app)

# AbacatePay — gateway de pagamento PIX.
# API key gerada em https://app.abacatepay.com → Configurações → Chaves de API.
# Sem essa key configurada, a carta é criada mas o checkout não é gerado
# (cai num fluxo "pagamento pendente" para admin marcar manualmente).
ABACATEPAY_API_KEY=
# Segredo configurado no painel do AbacatePay para autenticar o webhook.
ABACATEPAY_WEBHOOK_SECRET=
# 'dev' (default) ou 'prod' — apenas informativo.
ABACATEPAY_ENV=dev

# Painel admin (/admin) — protegido por cookie HMAC.
# ADMIN_PASSWORD: senha que o admin digita no login.
# ADMIN_SESSION_SECRET: chave secreta de assinatura do cookie. Min 16 chars.
#   Gerar com: openssl rand -hex 32
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
